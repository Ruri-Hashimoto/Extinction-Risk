    sp_risk <- rbind(sp_risk,sp_risk_2)
    sp_count_ACCESS <- sp_count_ACCESS + if_ycc_ACCESS
    sp_count_IPSL <- sp_count_IPSL + if_ycc_IPSL
    sp_count_MIROC6 <- sp_count_MIROC6 + if_ycc_MIROC6
    sp_count_MPI <- sp_count_MPI + if_ycc_MPI
    sp_count_MRI <- sp_count_MRI + if_ycc_MRI
    sp_count_mean <- sp_count_mean + if_ycc_mean
