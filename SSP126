  #####---DF calculation---####
  #############################
  
  ppb <- 6.21E-09 #濃度増分①[ppb.year/kg-CO2]
  Wm_ppb <- 1.4E-05 #濃度と放射強制力の関係② [Wm^-2.ppb^-2]
  Wm_26 <- 243.52 #85年間の放射強制力累積値_RCP2.6 [Wm^-2]
  #Wm_70 <- 372.995 #85年間の放射強制力累積値_RCP7.0③[Wm^-2]
  #DF = ①*②÷③*グリッド別の絶滅リスク[-/year]
  DF <- (ppb * Wm_ppb / Wm_26)*sp_eines_mean_90
  DF_re <- DF*10^6*10^6/tot #[E/MSY/ktonCO2]
  #DF <- expans * 3.9E-11 * 10000 / 2.83 #3.9E-11 [℃.year/ton-CO2], 2.83 (srcp7.0) [℃]　
  
  ###---ER LIST---##########################
